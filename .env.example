# Database configuration
DB_PORT=5432
DB_PASSWORD=postgres

# Keycloak configuration
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Data API Builder configuration
DAB_PORT=5000

# Blazor Web App configuration
WEB_PORT=8082
WEB_IMAGE=fboucher/kanban-dmz-web:latest

# Keycloak production configuration overrides (optional)
# Keycloak__Authority=https://keycloak.your-domain.com/realms/kanban-dmz
# Keycloak__ClientId=kanban-web
# Keycloak__ClientSecret=your-client-secret
# Keycloak__MetadataAddress=https://keycloak.your-domain.com/realms/kanban-dmz/.well-known/openid-configuration
