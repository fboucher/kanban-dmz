{
  "$schema": "https://github.com/Azure/data-api-builder/releases/latest/download/dab.draft.schema.json",
  "data-source": {
    "database-type": "postgresql",
    "connection-string": "@env('ConnectionStrings__kanban')",
    "options": {
      "set-session-context": false
    },
    "health": {
      "enabled": false
    }
  },
  "runtime": {
    "rest": {
      "enabled": true,
      "path": "/api"
    },
    "graphql": {
      "enabled": false
    },
    "host": {
      "mode": "development",
      "cors": {
        "origins": ["*"],
        "allow-credentials": false
      },
      "authentication": {
        "provider": "StaticWebApps"
      }
    }
  },
  "entities": {
    "Board": {
      "source": "board",
      "rest": true,
      "permissions": [
        {
          "role": "anonymous",
          "actions": ["read"]
        },
        {
          "role": "authenticated",
          "actions": ["*"]
        }
      ]
    },
    "Column": {
      "source": "kanban_column",
      "rest": true,
      "permissions": [
        {
          "role": "anonymous",
          "actions": ["read"]
        },
        {
          "role": "authenticated",
          "actions": ["*"]
        }
      ]
    },
    "Card": {
      "source": "card",
      "rest": true,
      "permissions": [
        {
          "role": "anonymous",
          "actions": [
            {
              "action": "read",
              "fields": {
                "include": ["id", "boardid", "columnid", "title", "publicdescription", "categoryid", "createdat", "createdby", "assignedto", "ispublic"]
              },
              "policy": {
                "database": "@item.ispublic eq true"
              }
            }
          ]
        },
        {
          "role": "authenticated",
          "actions": ["*"]
        }
      ]
    },
    "Category": {
      "source": "category",
      "rest": true,
      "permissions": [
        {
          "role": "anonymous",
          "actions": ["read"]
        },
        {
          "role": "authenticated",
          "actions": ["*"]
        }
      ]
    },
    "CardTag": {
      "source": "card_tag",
      "rest": true,
      "permissions": [
        {
          "role": "anonymous",
          "actions": ["read"]
        },
        {
          "role": "authenticated",
          "actions": ["*"]
        }
      ]
    }
  }
}
