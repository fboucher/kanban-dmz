@using Microsoft.FluentUI.AspNetCore.Components
@using KanbanDmz.Domain
@using KanbanDmz.Web.Components.Pages

<FluentDialogHeader ShowDismiss="true">
    <FluentStack VerticalAlignment="VerticalAlignment.Center" Gap="8px">
        @if (Content.IsEdit)
        {
            <FluentIcon Value="@(new Icons.Regular.Size24.Edit())" Color="Color.Primary" />
            <FluentLabel Typo="Typography.PaneHeader">Edit Card</FluentLabel>
        }
        else
        {
            <FluentIcon Value="@(new Icons.Regular.Size24.Add())" Color="Color.Primary" />
            <FluentLabel Typo="Typography.PaneHeader">Create Card</FluentLabel>
        }
    </FluentStack>
</FluentDialogHeader>

<FluentDialogBody>
    <FluentStack Orientation="Orientation.Vertical" Gap="15px" Style="width: 100%;">
        <!-- Title -->
        <FluentTextField Value="@Content.Title"
                         ValueChanged="@(EventCallback.Factory.Create<string>(this, val => Content.Title = val))"
                         Label="Title"
                         Required="true"
                         Style="width: 100%;"
                         Placeholder="Enter card title..." />
        
        <!-- Category & Column -->
        <FluentStack Orientation="Orientation.Horizontal" Gap="15px" Style="width: 100%;">
            <FluentSelect TOption="Category"
                          TValue="string"
                          Label="Category"
                          Items="Content.Categories"
                          OptionText="@(c => c.Name)"
                          OptionValue="@(c => c.Id.ToString())"
                          Placeholder="Select Category..."
                          Value="@SelectedCategoryIdString"
                          ValueChanged="@(EventCallback.Factory.Create<string>(this, val => SelectedCategoryIdString = val))"
                          Required="true"
                          Style="width: 100%;" />

            <FluentSelect TOption="Column"
                          TValue="string"
                          Label="Column"
                          Items="Content.Columns"
                          OptionText="@(c => c.Name)"
                          OptionValue="@(c => c.Id.ToString())"
                          Value="@SelectedColumnIdString"
                          ValueChanged="@(EventCallback.Factory.Create<string>(this, val => SelectedColumnIdString = val))"
                          Required="true"
                          Style="width: 100%;" />
        </FluentStack>

        <!-- Assignee & Tags -->
        <FluentStack Orientation="Orientation.Horizontal" Gap="15px" Style="width: 100%;">
            <FluentTextField Value="@Content.AssignedTo"
                             ValueChanged="@(EventCallback.Factory.Create<string>(this, val => Content.AssignedTo = val))"
                             Label="Assignee"
                             Placeholder="Username (e.g. Frank)"
                             Style="width: 100%;" />
            
            <FluentTextField Value="@Content.Tags"
                             ValueChanged="@(EventCallback.Factory.Create<string>(this, val => Content.Tags = val))"
                             Label="Tags"
                             Placeholder="Comma separated (e.g. ui, db)"
                             Style="width: 100%;" />
        </FluentStack>

        <!-- Visibility Checkbox -->
        <FluentCheckbox Value="@Content.IsPublic"
                        ValueChanged="@(EventCallback.Factory.Create<bool>(this, val => Content.IsPublic = val))"
                        Label="Visible to Public" />

        <!-- Public Description -->
        <FluentTextArea Value="@Content.PublicDescription"
                        ValueChanged="@(EventCallback.Factory.Create<string>(this, val => Content.PublicDescription = val))"
                        Label="Public Description"
                        Rows="3"
                        Style="width: 100%;"
                        Placeholder="Description visible to anyone..." />

        <!-- Private Description -->
        <FluentTextArea Value="@Content.PrivateDescription"
                        ValueChanged="@(EventCallback.Factory.Create<string>(this, val => Content.PrivateDescription = val))"
                        Label="Private Description"
                        Rows="3"
                        Style="width: 100%;"
                        Placeholder="Description visible only to authenticated users..." />
    </FluentStack>
</FluentDialogBody>

<FluentDialogFooter>
    @if (Content.IsEdit)
    {
        <FluentButton Appearance="ButtonAppearance.Outline" BackgroundColor="#ef4444" Color="#ffffff" OnClick="DeleteAsync" Style="margin-right: auto;">Delete Card</FluentButton>
    }
    <FluentButton Appearance="ButtonAppearance.Default" OnClick="CancelAsync">Cancel</FluentButton>
    <FluentButton Appearance="ButtonAppearance.Primary" OnClick="SaveAsync" Disabled="@(!IsValid)">Save</FluentButton>
</FluentDialogFooter>

@code {
    [Parameter]
    public CardDialogModel Content { get; set; } = default!;

    [CascadingParameter]
    public FluentDialogInstance Dialog { get; set; } = default!;

    public string SelectedCategoryIdString
    {
        get => Content.CategoryId == 0 ? "" : Content.CategoryId.ToString();
        set => Content.CategoryId = int.TryParse(value, out var id) ? id : 0;
    }

    public string SelectedColumnIdString
    {
        get => Content.ColumnId.ToString();
        set => Content.ColumnId = Guid.TryParse(value, out var guid) ? guid : Guid.Empty;
    }

    private bool IsValid => !string.IsNullOrWhiteSpace(Content.Title) && Content.CategoryId != 0 && Content.ColumnId != Guid.Empty;

    private async Task SaveAsync()
    {
        if (IsValid)
        {
            await Dialog.DialogInstance.CloseAsync(Content);
        }
    }

    private async Task CancelAsync()
    {
        await Dialog.DialogInstance.CancelAsync();
    }

    private async Task DeleteAsync()
    {
        Content.IsDelete = true;
        await Dialog.DialogInstance.CloseAsync(Content);
    }
}
