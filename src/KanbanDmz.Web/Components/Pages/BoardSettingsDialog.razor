@using Microsoft.FluentUI.AspNetCore.Components
@using KanbanDmz.Domain
@using KanbanDmz.Domain.DTOs
@using KanbanDmz.Web.Services
@inject KanbanService KanbanService

<FluentDialogBody>
    <TitleTemplate>
        <FluentStack VerticalAlignment="VerticalAlignment.Center" Gap="8px">
            <FluentIcon Value="@(new Icons.Regular.Size24.Settings())" Color="Color.Primary" />
            <FluentLabel Typo="Typography.PaneHeader">Board Settings</FluentLabel>
        </FluentStack>
    </TitleTemplate>
    <ChildContent>
        <FluentStack Orientation="Orientation.Vertical" Gap="15px" Style="width: 100%;">
            @if (_errorMessage != null)
            {
                <div style="background-color: #fee2e2; color: #ef4444; border: 1px solid #fca5a5; padding: 10px; border-radius: 4px; font-weight: 500; font-size: 0.9rem; width: 100%; box-sizing: border-box;">
                    <span>@_errorMessage</span>
                </div>
            }

            <FluentTextInput @bind-Value="Board.Name"
                             Label="Board Name"
                             Required="true"
                             Style="width: 100%;" />

            <FluentCheckbox @bind-Value="Board.IsPublic"
                            Label="Visible to Public" />

            <FluentCheckbox @bind-Value="_hasBackgroundColor"
                            Label="Custom Background Color" />

            @if (_hasBackgroundColor)
            {
                <div style="display: flex; align-items: center; gap: 12px;">
                    <label style="font-size: 0.9rem; font-weight: 500; color: var(--neutral-foreground-rest);">Background Color:</label>
                    <input type="color" @bind="_backgroundColor"
                           style="width: 44px; height: 36px; border: 1px solid var(--neutral-stroke-rest); border-radius: 4px; padding: 2px; cursor: pointer; background: none;" />
                    <span style="font-size: 0.85rem; color: var(--neutral-foreground-hint); font-family: monospace;">@_backgroundColor</span>
                </div>
            }
        </FluentStack>
    </ChildContent>
    <ActionTemplate>
        <FluentButton Appearance="ButtonAppearance.Outline" OnClick="CancelAsync">Cancel</FluentButton>
        <FluentButton Appearance="ButtonAppearance.Primary" OnClick="SaveAsync" Disabled="@(string.IsNullOrWhiteSpace(Board.Name))">Save</FluentButton>
    </ActionTemplate>
</FluentDialogBody>

@code {
    [Parameter]
    public KanbanDmz.Domain.Board Board { get; set; } = default!;

    [CascadingParameter]
    public IDialogInstance DialogInstance { get; set; } = default!;

    private string? _errorMessage;
    private string _backgroundColor = "#ffffff";
    private bool _hasBackgroundColor;

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(Board.BackgroundColor))
        {
            _backgroundColor = Board.BackgroundColor;
            _hasBackgroundColor = true;
        }
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(Board.Name)) return;

        try
        {
            Board.BackgroundColor = _hasBackgroundColor ? _backgroundColor : null;
            var success = await KanbanService.UpdateBoardAsync(Board);
            if (success)
            {
                await DialogInstance.CloseAsync(true);
            }
            else
            {
                _errorMessage = "Failed to update board settings.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
    }

    private async Task CancelAsync()
    {
        await DialogInstance.CancelAsync();
    }
}
