@inherits LayoutComponentBase
@using Microsoft.FluentUI.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation
@inject IThemeService ThemeService
@inject IJSRuntime JSRuntime

<FluentLayout>
    <FluentLayoutItem Area="@LayoutArea.Header">
        <FluentStack VerticalAlignment="VerticalAlignment.Center">
            <div class="brand" @onclick="NavigateToHome" style="cursor: pointer; user-select: none;" title="Home">
                <span class="brand-icon">
                    <FluentIcon Value="@(new Icons.Filled.Size24.Board())" Color="Color.Primary" />
                </span>
                <span class="brand-name">Kanban DMZ</span>
            </div>
            
            <FluentSpacer />
            
            <div class="auth-section" style="display: flex; align-items: center; gap: 8px;">
                <span style="font-size: 0.8rem; font-weight: 600; color: var(--neutral-foreground-hint);">Theme:</span>
                <FluentSelect TOption="AppTheme"
                              TValue="AppTheme"
                              Items="@_themes"
                              OptionText="@(t => t.Name)"
                              Value="@_selectedTheme"
                              ValueChanged="OnThemeChanged"
                              Style="min-width: 150px; margin-right: 8px;" />
                <AuthorizeView>
                    <Authorized>
                        <div class="user-info">
                            <span class="user-avatar" title="@(context.User.Identity?.Name ?? "User")">
                                @GetInitials(context.User.Identity?.Name)
                            </span>
                            <span class="user-name">@(context.User.Identity?.Name ?? "Authenticated User")</span>
                        </div>
                        <FluentButton Appearance="ButtonAppearance.Subtle" OnClick="Logout" IconEnd="@(new Icons.Regular.Size16.ArrowExit())">
                            Log out
                        </FluentButton>
                    </Authorized>
                    <NotAuthorized>
                        <FluentButton Appearance="ButtonAppearance.Primary" OnClick="Login" IconStart="@(new Icons.Regular.Size16.ArrowEnter())">
                            Log in
                        </FluentButton>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </FluentStack>
    </FluentLayoutItem>

    <FluentLayoutItem Area="@LayoutArea.Navigation" Width="@(_menuExpanded ? "250px" : "60px")">
        <NavMenu @bind-Expanded="_menuExpanded" @bind-Expanded:after="StateHasChanged" />
    </FluentLayoutItem>

    <FluentLayoutItem Area="@LayoutArea.Content" Padding="@Padding.All3">
        @Body
    </FluentLayoutItem>

    <FluentLayoutItem Area="@LayoutArea.Footer">
        <FluentStack VerticalAlignment="VerticalAlignment.Center" Width="100%">
            <span>Kanban DMZ &copy; 2026</span>
            <FluentSpacer />
            <a href="https://github.com/fboucher/kanban-dmz" target="_blank" style="display: inline-flex; align-items: center; gap: 6px; text-decoration: none; color: var(--neutral-foreground-rest);">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" style="vertical-align: middle;">
                    <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"/>
                </svg>
                <span>source</span>
            </a>
            <FluentSpacer />
            <span class="version-label">v@(typeof(Program).Assembly.GetName().Version?.ToString(3) ?? "0.1.0")</span>
        </FluentStack>
    </FluentLayoutItem>
</FluentLayout>

<FluentDialogProvider />
<FluentProviders />

@code {
    private ThemeMode _mode = ThemeMode.System;
    private bool _menuExpanded = true;

    private class AppTheme
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? BrandColor { get; set; }
        public ThemeMode Mode { get; set; }
    }

    private List<AppTheme> _themes = new()
    {
        new() { Id = "system", Name = "System Default", Mode = ThemeMode.System },
        new() { Id = "light", Name = "Light Mode", Mode = ThemeMode.Light },
        new() { Id = "dark", Name = "Dark Mode", Mode = ThemeMode.Dark },
        new() { Id = "tokyo-night", Name = "Tokyo Night", BrandColor = "#7aa2f7", Mode = ThemeMode.Dark },
        new() { Id = "catppuccin-dark", Name = "Catppuccin Dark", BrandColor = "#c6a0f6", Mode = ThemeMode.Dark },
        new() { Id = "catppuccin-light", Name = "Catppuccin Light", BrandColor = "#8839ef", Mode = ThemeMode.Light },
        new() { Id = "solarized-dark", Name = "Solarized Dark", BrandColor = "#268bd2", Mode = ThemeMode.Dark },
        new() { Id = "solarized-light", Name = "Solarized Light", BrandColor = "#268bd2", Mode = ThemeMode.Light },
        new() { Id = "synthwave84", Name = "SynthWave '84", BrandColor = "#f92aad", Mode = ThemeMode.Dark }
    };

    private AppTheme _selectedTheme = new() { Id = "system", Name = "System Default", Mode = ThemeMode.System };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var savedThemeId = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", "kanban-dmz:theme-id");
            if (!string.IsNullOrEmpty(savedThemeId))
            {
                var theme = _themes.FirstOrDefault(t => t.Id == savedThemeId);
                if (theme != null)
                {
                    await OnThemeChanged(theme);
                    StateHasChanged();
                    return;
                }
            }

            var isDark = await ThemeService.IsDarkModeAsync();
            _mode = isDark ? ThemeMode.Dark : ThemeMode.Light;
            StateHasChanged();
        }
    }

    private async Task OnThemeChanged(AppTheme theme)
    {
        _selectedTheme = theme;
        _mode = theme.Mode;

        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "kanban-dmz:theme-id", theme.Id);

        if (!string.IsNullOrEmpty(theme.BrandColor))
        {
            var settings = new ThemeSettings
            {
                Color = theme.BrandColor,
                Mode = theme.Mode
            };
            await ThemeService.SetThemeAsync(settings);
        }
        else
        {
            await ThemeService.SetThemeAsync(theme.Mode);
        }

        await JSRuntime.InvokeVoidAsync("document.body.setAttribute", "data-theme-name", theme.Id);
        
        var resolvedMode = theme.Mode;
        if (resolvedMode == ThemeMode.System)
        {
            var isSystemDark = await ThemeService.IsSystemDarkAsync();
            resolvedMode = isSystemDark ? ThemeMode.Dark : ThemeMode.Light;
        }
        await JSRuntime.InvokeVoidAsync("document.body.setAttribute", "data-theme", resolvedMode == ThemeMode.Dark ? "dark" : "light");
    }

    private void NavigateToHome()
    {
        Navigation.NavigateTo("/");
    }

    private void Login()
    {
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    private void Logout()
    {
        Navigation.NavigateTo("/logout", forceLoad: true);
    }

    private string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "U";
        if (parts.Length == 1) return parts[0][0].ToString().ToUpperInvariant();
        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpperInvariant();
    }
}
