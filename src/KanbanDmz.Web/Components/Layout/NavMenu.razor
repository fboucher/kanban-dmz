@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization

<FluentNav Width="100%">
    <FluentNavItem Href="/" Match="NavLinkMatch.All" IconRest="@(new Icons.Regular.Size20.Home())" IconActive="@(new Icons.Filled.Size20.Home())">
        Home
    </FluentNavItem>
    <FluentNavItem Href="/board" Match="NavLinkMatch.All" IconRest="@(new Icons.Regular.Size20.Board())" IconActive="@(new Icons.Filled.Size20.Board())">
        Kanban Board
    </FluentNavItem>
    <AuthorizeView>
        <Authorized>
            <FluentNavItem Href="/categories" Match="NavLinkMatch.All" IconRest="@(new Icons.Regular.Size20.Tag())" IconActive="@(new Icons.Filled.Size20.Tag())">
                Categories
            </FluentNavItem>
        </Authorized>
    </AuthorizeView>
</FluentNav>
